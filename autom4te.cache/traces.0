        if(!ipv6ptr)
          return 1; /* fail */
        if(ipv6ptr != ipv6res)
          return 1; /* fail */
        if(!ipv6ptr[0])
          return 1; /* fail */
        if(memcmp(ipv6res, "fe80::214:4fff:fe0b:76c8", 24) != 0)
